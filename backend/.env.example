SECRET_KEY=foodbridge-secret-key-change-in-production
JWT_SECRET_KEY=foodbridge-jwt-secret-change-in-production

# Render injects DATABASE_URL automatically when the database is linked.
# For local development, SQLite is used if DATABASE_URL is left blank.
DATABASE_URL=

MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USE_SSL=False
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_DEFAULT_SENDER=noreply@foodbridge.com

FRONTEND_URL=http://localhost:5173
GOOGLE_MAPS_KEY=
